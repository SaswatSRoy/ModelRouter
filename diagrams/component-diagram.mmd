%% Component Diagram — ModelRouter
graph TB
    subgraph Clients
        SDKJava[sdk-java]
        SDKAndroid[sdk-android]
        RESTClient[REST / gRPC client]
    end

    subgraph Gateway["modelrouter-gateway"]
        Ingress["router-ingress<br/>WebFlux, REST/gRPC/SSE"]
